{
  "name": "pi-desktop-notify",
  "version": "1.0.1",
  "description": "Focus-aware desktop notifications for pi · from yapp",
  "author": "mgabor3141",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/mgabor3141/yapp.git",
    "directory": "packages/desktop-notify"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "yapp"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./extension": {
      "import": "./dist/extension.js",
      "types": "./dist/extension.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "pi": {
    "extensions": [
      "dist/extension.js"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.0",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
