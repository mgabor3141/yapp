{
  "name": "pi-bash-trim",
  "version": "1.0.0",
  "description": "Smart bash output trimming for pi to fit LLM context budgets",
  "author": "mgabor3141",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/mgabor3141/yapp.git",
    "directory": "packages/bash-trim"
  },
  "keywords": [
    "pi-package",
    "output-trimming",
    "token-budget"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.57.0",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
